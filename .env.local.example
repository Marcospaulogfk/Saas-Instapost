# ============================================
# InstaPost - Variáveis de Ambiente
# ============================================
# Copie este arquivo para .env.local e preencha os valores reais
# NUNCA commite .env.local no Git

# ----- Supabase -----
# Pegue em: https://supabase.com/dashboard/project/[seu-projeto]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_publishable_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# ----- Anthropic (Claude API) -----
# Pegue em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ----- Fal.ai (geração de imagem) -----
# Pegue em: https://fal.ai/dashboard/keys
FAL_KEY=...

# ----- Unsplash (fotos stock) -----
# Pegue em: https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=...

# ----- Stripe (pagamentos) -----
# Pegue em: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ----- Cloudflare Turnstile (anti-bot) -----
# Pegue em: https://dash.cloudflare.com/?to=/:account/turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=...
TURNSTILE_SECRET_KEY=...

# ----- App URL -----
# Em desenvolvimento: http://localhost:3000
# Em produção: https://seudominio.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Dev Mode (server-only, NUNCA prefixar com NEXT_PUBLIC_) -----
# true => bypass de auth no dashboard, usando o user real configurado em DEV_USER_ID.
# Em produção, NODE_ENV=production força bypass desativado mesmo com true (defesa em camadas).
DEV_MODE=true

# UUID do seu usuário real em auth.users (NÃO crie um usuário fake — use sua conta).
# Como pegar:
#   Supabase Dashboard > Authentication > Users > clique no seu email > "User UID"
#   ou no SQL Editor: SELECT id FROM auth.users WHERE email = 'seu@email.com';
DEV_USER_ID=

# ----- Brevo (email transacional, opcional inicial) -----
BREVO_API_KEY=...
